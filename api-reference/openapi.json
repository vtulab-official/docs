{
  "openapi": "3.1.0",
  "info": {
    "title": "VTULab API",
    "version": "1.0.0",
    "description": "VTU and identity verification endpoints."
  },
  "servers": [
    {
      "url": "https://api.example.com",
      "description": "Production API subdomain"
    },
    {
      "url": "https://example.com/api",
      "description": "Non-production Laravel API prefix"
    }
  ],
  "paths": {
    "/": {
      "get": {
        "summary": "API health",
        "responses": {
          "200": {
            "description": "Service online"
          }
        }
      }
    },
    "/v1/vtu/data": {
      "post": {
        "summary": "Purchase data",
        "security": [
          {
            "bearerAuth": []
          },
          {
            "apiKeyHeader": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DataPurchaseRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Data purchase successful"
          },
          "400": {
            "description": "Request failed"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/v1/vtu/airtime": {
      "post": {
        "summary": "Purchase airtime",
        "security": [
          {
            "bearerAuth": []
          },
          {
            "apiKeyHeader": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AirtimePurchaseRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Airtime purchase successful"
          },
          "400": {
            "description": "Request failed"
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/v1/identity/nin/verify": {
      "post": {
        "summary": "Verify NIN",
        "security": [
          {
            "bearerAuth": []
          },
          {
            "apiKeyHeader": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/NinVerifyRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "NIN verified"
          }
        }
      }
    },
    "/v1/identity/nin/retrieve": {
      "post": {
        "summary": "Retrieve NIN by phone number",
        "security": [
          {
            "bearerAuth": []
          },
          {
            "apiKeyHeader": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/NinRetrieveRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "NIN retrieval successful"
          }
        }
      }
    },
    "/v1/identity/bvn/verify": {
      "post": {
        "summary": "Verify BVN",
        "security": [
          {
            "bearerAuth": []
          },
          {
            "apiKeyHeader": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BvnVerifyRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "BVN verification successful"
          }
        }
      }
    },
    "/v1/identity/bvn/retrieve": {
      "post": {
        "summary": "Retrieve BVN by phone number",
        "security": [
          {
            "bearerAuth": []
          },
          {
            "apiKeyHeader": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BvnRetrieveRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "BVN retrieval successful"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer"
      },
      "apiKeyHeader": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-KEY"
      }
    },
    "schemas": {
      "DataPurchaseRequest": {
        "type": "object",
        "required": ["plan_id", "phone_number"],
        "properties": {
          "plan_id": { "type": "integer", "example": 12 },
          "phone_number": { "type": "string", "example": "08012345678" }
        }
      },
      "AirtimePurchaseRequest": {
        "type": "object",
        "required": ["network", "phone_number", "amount"],
        "properties": {
          "network": { "type": "string", "enum": ["mtn", "airtel", "glo", "9mobile"] },
          "phone_number": { "type": "string", "example": "08012345678" },
          "amount": { "type": "number", "minimum": 50, "example": 100 }
        }
      },
      "NinVerifyRequest": {
        "type": "object",
        "required": ["nin", "is_consent"],
        "properties": {
          "nin": { "type": "string", "example": "12345678901" },
          "is_consent": { "type": "boolean", "example": true }
        }
      },
      "NinRetrieveRequest": {
        "type": "object",
        "required": ["phone_number", "is_consent"],
        "properties": {
          "phone_number": { "type": "string", "example": "08012345678" },
          "is_consent": { "type": "boolean", "example": true }
        }
      },
      "BvnVerifyRequest": {
        "type": "object",
        "required": ["bvn", "is_consent"],
        "properties": {
          "bvn": { "type": "string", "example": "12345678901" },
          "is_consent": { "type": "boolean", "example": true }
        }
      },
      "BvnRetrieveRequest": {
        "type": "object",
        "required": ["phone_number", "is_consent"],
        "properties": {
          "phone_number": { "type": "string", "example": "08012345678" },
          "is_consent": { "type": "boolean", "example": true }
        }
      }
    }
  }
}
